# ─── EcoReward – Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.

# ── Server ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── MongoDB ──────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/ecoreward

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ── Cloudinary ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (Nodemailer / SendGrid) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@ecoreward.in

# ── AI / Roboflow (optional) ─────────────────────────────────────
ROBOFLOW_API_KEY=your_roboflow_key
ROBOFLOW_MODEL_URL=https://detect.roboflow.com/garbage-detection/1

# ── Google Maps (frontend) ────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Firebase (alternative to Cloudinary) ─────────────────────────
# FIREBASE_PROJECT_ID=your_project
# FIREBASE_PRIVATE_KEY=your_key
# FIREBASE_CLIENT_EMAIL=your@service.com
# FIREBASE_STORAGE_BUCKET=your_bucket.appspot.com
